# ============================================================================
# Gmail -> Apple Mail Push Bridge — environment template
# Copy to `.env` and fill in.  The real `.env` is gitignored (public repo).
# ============================================================================

# --- Public identity of THIS bridge -----------------------------------------
# The FQDN iOS will connect to. Must resolve publicly and have port 443 open.
BRIDGE_FQDN=push.example.com
# Email used for Let's Encrypt registration (expiry notices).
ACME_EMAIL=you@example.com

# --- The Gmail account being bridged ----------------------------------------
GMAIL_ADDRESS=yourname@gmail.com
# Google *App Password* (16 chars, no spaces). Requires 2-Step Verification.
# Used by: Watcher IMAP IDLE, mbsync, and Postfix SASL relay.
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# --- Local bridge credentials (iOS enters these as the Exchange user/pass) ---
# These are internal to the bridge; pick strong values. NOT your Google login.
LOCAL_BRIDGE_USER=bridgeuser
LOCAL_BRIDGE_PASS=change-me-to-a-long-random-string

# --- Tuning ------------------------------------------------------------------
# Fallback periodic sync (seconds) in addition to event-driven IDLE.
# Also propagates iPhone-side read/flag changes back up to Gmail.
SYNC_INTERVAL=45
# How often Z-Push re-checks Dovecot during a Ping (push latency ceiling, sec).
PING_INTERVAL=30

# --- Image coordinates (GHCR, public) ---------------------------------------
# Overridden in CI; for local `docker compose up` these pull public images.
IMAGE_OWNER=akvaithi
IMAGE_TAG=latest
